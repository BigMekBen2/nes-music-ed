<Application x:Class="NESMusicEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- NES/DOS Retro Color Palette -->
        <SolidColorBrush x:Key="BgDark" Color="#0F0F1A"/>
        <SolidColorBrush x:Key="BgPanel" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="BgStaff" Color="#16213E"/>
        <SolidColorBrush x:Key="BgControl" Color="#0D0D1F"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#39FF14"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#00FFFF"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#FFE000"/>
        <SolidColorBrush x:Key="AccentMagenta" Color="#FF00FF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#D0D0E0"/>
        <SolidColorBrush x:Key="TextDim" Color="#7070A0"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3A3A6A"/>
        <SolidColorBrush x:Key="BorderBright" Color="#5050A0"/>
        <SolidColorBrush x:Key="StaffLine" Color="#2A4A6A"/>

        <!-- Base retro button style -->
        <Style x:Key="RetroButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#D0D0E0"/>
            <Setter Property="BorderBrush" Value="#5050A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A4E"/>
                                <Setter Property="BorderBrush" Value="#00FFFF"/>
                                <Setter Property="Foreground" Value="#00FFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0A0A1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button (play/stop) -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource RetroButton}">
            <Setter Property="Foreground" Value="#39FF14"/>
            <Setter Property="BorderBrush" Value="#39FF14"/>
        </Style>

        <!-- Stop button -->
        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource RetroButton}">
            <Setter Property="Foreground" Value="#FF4444"/>
            <Setter Property="BorderBrush" Value="#FF4444"/>
        </Style>

        <!-- Instrument list item button -->
        <Style x:Key="InstrumentButton" TargetType="Button" BasedOn="{StaticResource RetroButton}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- ComboBox style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0D0D1F"/>
            <Setter Property="Foreground" Value="#D0D0E0"/>
            <Setter Property="BorderBrush" Value="#3A3A6A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Label style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#7070A0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D0D0E0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- RadioButton style -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#D0D0E0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Slider style -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#39FF14"/>
        </Style>

        <!-- Separator style -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#3A3A6A"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>

        <!-- Menu style -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#0F0F1A"/>
            <Setter Property="Foreground" Value="#D0D0E0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#3A3A6A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#0F0F1A"/>
            <Setter Property="Foreground" Value="#D0D0E0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- ScrollBar style - thin retro look -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#0D0D1F"/>
        </Style>
    </Application.Resources>
</Application>
